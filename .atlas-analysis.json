  "keyFeatures": [
    "Composable feature system — mix and match player capabilities (playback, volume, fullscreen, PiP, text tracks, etc.)",
    "Multi-platform support — React components, HTML custom elements, and React Native",
    "Presets — pre-packaged player configurations for video, audio, and background use cases",
    "Skinnable UI — use built-in skins or compose from individual UI components",
    "TypeScript-first — fully typed API surface with generics for state inference",
    "HLS and DASH support via hls.js and dash.js built-in",
    "Accessible by default — ARIA roles, keyboard navigation, and focus management",
    "Tree-shakeable packages with development/production builds"
  ],
  "publicApiSurface": [
    "createPlayer() — @videojs/react and @videojs/html",
    "Player.Provider / <video-player> — state provider",
    "Player.Container / <media-container> — layout container",
